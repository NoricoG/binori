{
    "compilerOptions": {
        "target": "es2023",
        "lib": [
            "es2023",
            "dom"
        ],
        "module": "es2022",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@puzzle/*": [
                "src/puzzle/*"
            ],
            "@tools/*": [
                "src/tools/*"
            ],
            "@ui/*": [
                "src/ui/*"
            ]
        }
    }
}
